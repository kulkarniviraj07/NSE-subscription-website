PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=database_name
DB_USER=username
DB_PASSWORD=password

JWT_SECRET=your_jwt_secret

RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ── TEMPORARY — Razorpay test-mode login (username/password) ──────────────
# Remove once Razorpay's integration testing is complete (see authController.js
# / authRoutes.js / POST /api/auth/login-test).
TEMP_RAZORPAY_TEST_USERNAME=testuser123razorpay
TEMP_RAZORPAY_TEST_PASSWORD=razorpay@test123

# ── Pureframe Central Dashboard integration ────────────────────────────────
# Shared secret the Central Dashboard presents on every /api/admin/v1/*
# request (header: x-central-api-key). Generate with `openssl rand -hex 32`.
# Register this exact same value for this product in the dashboard's
# Control Panel → Products → Register product.
CENTRAL_API_KEY=