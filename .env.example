# ============================================================
#  .env.example  —  Required environment variables
#
#  Copy to .env for local docker-compose, OR set these in the
#  Coolify dashboard (Environment Variables) for production.
#  NEVER commit real values — .env is gitignored.
# ============================================================

# ── Database (Postgres) ─────────────────────────────────────
# DB_PASSWORD is shared by the db, backend, bot and scraper services.
# IMPORTANT: the Postgres volume is initialised with this password on
# FIRST run only. If a volume already exists, keep the SAME value or
# Postgres will reject connections.
DB_USER=postgres
DB_PASSWORD=

# ── WhatsApp Cloud API (Meta) — used by the notification bot only ──
# Permanent token from a Meta System User. Rotate if ever exposed.
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=1094754613731490
VERIFY_TOKEN=nse_bot_secret_2024

# ── Backend auth / payments ─────────────────────────────────
JWT_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# ── MSG91 SMS OTP ──────────────────────────────────────────
# Auth key for server-side access-token verification (verifyAccessToken API).
MSG91_AUTH_KEY=521126AskU4DuQkfU6a461ed8P1
# Widget ID and token-auth are public and go into the frontend .env
MSG91_WIDGET_ID=366762684262393039393836
MSG91_TOKEN_AUTH=521126T3jK0puIc6a462148P1

# ── Optional ────────────────────────────────────────────────
OPENAI_API_KEY=
PORTAL_URL=

# 100-percent-off premium coupon code (no payment). Default: PUREFRAME100
PREMIUM_COUPON_100=PUREFRAME100

# ── Per-mobile company-limit override (owner / test accounts) ───────────
# Plans: FREE = 10 companies, PREMIUM = 25 companies (₹149/mo).
# Numbers listed here ignore their plan's limit and get COMPANY_LIMIT_OVERRIDE
# instead. Comma-separated; country code optional ("7057004992" == "917057004992").
# Leave empty to disable. Keep real numbers OUT of git — set these in Coolify.
COMPANY_LIMIT_OVERRIDE_MOBILES=
COMPANY_LIMIT_OVERRIDE=150

# ── Dedicated WhatsApp template for quarterly RESULTS filings ───────────
# Set once "nse_result_bits" is APPROVED; results then use the metrics-table
# template. Empty = results keep using TEMPLATE_NAME.
TEMPLATE_RESULT_NAME=
