# ============================================================
#  .env.example  —  Required environment variables
#
#  Copy to .env for local docker-compose, OR set these in the
#  Coolify dashboard (Environment Variables) for production.
#  NEVER commit real values — .env is gitignored.
# ============================================================

# ── Database (Postgres) ─────────────────────────────────────
# DB_PASSWORD is shared by the db, backend, bot and scraper services.
# IMPORTANT: the Postgres volume is initialised with this password on
# FIRST run only. If a volume already exists, keep the SAME value or
# Postgres will reject connections.
DB_USER=postgres
DB_PASSWORD=

# ── WhatsApp Cloud API (Meta) ───────────────────────────────
# Permanent token from a Meta System User. Rotate if ever exposed.
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=1094754613731490
VERIFY_TOKEN=nse_bot_secret_2024

# ── Backend auth / payments ─────────────────────────────────
JWT_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
MSG91_AUTH_KEY=

# ── Optional ────────────────────────────────────────────────
OPENAI_API_KEY=
PORTAL_URL=

# 100-percent-off premium coupon code (no payment). Default: PUREFRAME100
PREMIUM_COUPON_100=PUREFRAME100
